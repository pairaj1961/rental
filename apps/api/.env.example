# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/rental_db"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=8h

# File Storage
UPLOADS_DIR=./uploads
STORAGE_DRIVER=local

# CORS — frontend URL
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
