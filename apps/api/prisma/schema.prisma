generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "rental"]
}

// ─── public schema: User only (auth) ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         String
  phone        String?
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @map("updated_at")

  @@schema("public")
  @@map("users")
}

// ─── rental schema ────────────────────────────────────────────────────────────

model Equipment {
  id              String    @id @default(cuid())
  productId       String    @map("product_id")
  serialNumber    String    @unique @map("serial_number")
  assetTag        String?   @map("asset_tag")
  condition       String    @default("GOOD")
  status          String    @default("AVAILABLE")
  purchaseDate    DateTime? @map("purchase_date")
  purchasePrice   Float?    @map("purchase_price")
  currentLocation String?   @map("current_location")
  notes           String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  contractItems      RentalContractItem[]
  maintenanceRecords MaintenanceRecord[]

  @@schema("rental")
  @@map("equipment")
}

model RentalContract {
  id                   String    @id @default(cuid())
  contractNumber       String    @unique @map("contract_number")
  customerId           String    @map("customer_id")
  siteId               String?   @map("site_id")
  assignedRepId        String    @map("assigned_rep_id")
  approvedById         String?   @map("approved_by_id")
  status               String    @default("DRAFT")
  startDate            DateTime  @map("start_date")
  endDate              DateTime  @map("end_date")
  actualReturnDate     DateTime? @map("actual_return_date")
  depositAmount        Float     @default(0) @map("deposit_amount")
  totalAmount          Float     @default(0) @map("total_amount")
  paymentStatus        String    @default("UNPAID") @map("payment_status")
  convertedFromQuoteId String?   @map("converted_from_quote_id")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  items             RentalContractItem[]
  deliverySchedules DeliverySchedule[]
  invoices          RentalInvoice[]

  @@schema("rental")
  @@map("rental_contracts")
}

model RentalContractItem {
  id             String @id @default(cuid())
  contractId     String @map("contract_id")
  equipmentId    String @map("equipment_id")
  productId      String @map("product_id")
  quantity       Int    @default(1)
  agreedRate     Float  @map("agreed_rate")
  agreedRateType String @map("agreed_rate_type")
  subtotal       Float  @default(0)
  notes          String?

  contract  RentalContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  equipment Equipment      @relation(fields: [equipmentId], references: [id])

  @@schema("rental")
  @@map("rental_contract_items")
}

model DeliverySchedule {
  id            String    @id @default(cuid())
  contractId    String    @map("contract_id")
  type          String
  scheduledDate DateTime  @map("scheduled_date")
  actualDate    DateTime? @map("actual_date")
  address       String?
  province      String?
  driverName    String?   @map("driver_name")
  driverPhone   String?   @map("driver_phone")
  vehiclePlate  String?   @map("vehicle_plate")
  status        String    @default("SCHEDULED")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  contract RentalContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@schema("rental")
  @@map("delivery_schedules")
}

model MaintenanceRecord {
  id             String    @id @default(cuid())
  equipmentId    String    @map("equipment_id")
  type           String
  scheduledDate  DateTime  @map("scheduled_date")
  completedDate  DateTime? @map("completed_date")
  description    String?
  technicianName String?   @map("technician_name")
  laborCost      Float     @default(0) @map("labor_cost")
  partsCost      Float     @default(0) @map("parts_cost")
  totalCost      Float     @default(0) @map("total_cost")
  status         String    @default("SCHEDULED")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")

  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@schema("rental")
  @@map("maintenance_records")
}

model RentalInvoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique @map("invoice_number")
  contractId    String    @map("contract_id")
  invoiceDate   DateTime  @map("invoice_date")
  dueDate       DateTime  @map("due_date")
  subtotal      Float     @default(0)
  taxRate       Float     @default(7) @map("tax_rate")
  taxAmount     Float     @default(0) @map("tax_amount")
  discount      Float     @default(0)
  total         Float     @default(0)
  status        String    @default("DRAFT")
  paidAt        DateTime? @map("paid_at")
  paidAmount    Float?    @map("paid_amount")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  contract RentalContract @relation(fields: [contractId], references: [id])

  @@schema("rental")
  @@map("rental_invoices")
}

model RentalAuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])

  @@schema("rental")
  @@map("rental_audit_logs")
}

model RentalSettings {
  id          String   @id @default("singleton")
  companyName String   @default("Equipment Rental") @map("company_name")
  depositRate Float    @default(20) @map("deposit_rate")
  lateFeePerDay Float  @default(0) @map("late_fee_per_day")
  taxRate     Float    @default(7) @map("tax_rate")
  currency    String   @default("THB")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@schema("rental")
  @@map("rental_settings")
}
